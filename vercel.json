{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "tsx scripts/copy-fonts.ts && tsc -p tsconfig.json && cp -R public/. dist/ && mkdir -p dist/demo && cp -R demo/. dist/demo/",
  "outputDirectory": "dist",
  "functions": {
    "api/mcp.ts": {
      "maxDuration": 300
    },
    "api/events.ts": {
      "maxDuration": 10
    },
    "api/simulate.ts": {
      "maxDuration": 300
    },
    "api/dashboard.ts": {
      "maxDuration": 10
    },
    "api/r.ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/dashboard", "destination": "/api/dashboard" },
    { "source": "/r/:runId", "destination": "/api/r?runId=:runId" },
    { "source": "/r/:runId/sim", "destination": "/api/r?runId=:runId&view=sim" }
  ]
}
